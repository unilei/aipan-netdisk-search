# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aipan
DATABASE_SCHEMA=public
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/aipan?schema=public
SHADOW_DATABASE_URL=postgresql://postgres:change-me@localhost:5432/aipan_shadow?schema=public

# Admin
ADMIN_USER=admin
ADMIN_PASSWORD=change-me
ADMIN_EMAIL=admin@example.com

# Security
JWT_SECRET=change-me
SETTINGS_ENCRYPTION_KEY=change-me
NODE_ENV=development

# WebSocket / Redis
WS_PORT=3002
NUXT_PUBLIC_WS_PORT=3002
REDIS_URL=redis://localhost:6379

# Elasticsearch for published UserResource search index
# Local dev can leave these empty. Production should use HTTPS + Basic Auth + CA fingerprint.
ELASTICSEARCH_NODE=
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_CA_FINGERPRINT=
ELASTICSEARCH_USER_RESOURCE_INDEX=user-resources

# Auto review after users submit or update UserResource
USER_RESOURCE_AUTO_REVIEW_ENABLED=true
USER_RESOURCE_AUTO_REVIEW_APPROVE_VALID=true
USER_RESOURCE_AUTO_REVIEW_REJECT_INVALID=true
USER_RESOURCE_AUTO_REVIEW_REQUIRE_REACHABLE=false
USER_RESOURCE_AUTO_REVIEW_NOTIFY_USER=true
USER_RESOURCE_AUTO_REVIEW_NOTIFY_EMAIL=true
USER_RESOURCE_AUTO_REVIEW_MAX_LINKS=5

# Optional PanSou fallback APIs for /api/sources/10
PANSOU_API_URLS=https://so.252035.xyz/api/search,https://pansou.aipan.me/api/search,https://pansou.app/api/search

# Optional GitHub image/resource storage
NUXT_PUBLIC_GITHUB_OWNER=
NUXT_PUBLIC_GITHUB_REPO=
NUXT_PUBLIC_GITHUB_TOKEN=
NUXT_PUBLIC_GITHUB_BRANCH=main

# Optional Quark integration
NUXT_PUBLIC_QUARK_COOKIE=

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
// npx prisma migrate dev --name add_resource_table

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  // binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL") // 添加这一行
}

model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique
  email       String   @unique
  password    String
  role        String   @default("user") // Possible values: "admin", "user"
  status      String   @default("active") // Possible values: "active", "disabled"
  avatarStyle String   @default("avataaars") // 头像风格
  salt        String? // 用于密码哈希的盐
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isVerified  Boolean  @default(false)

  resources     Resource[] // 一个用户可以有多个资源
  resourceTypes ResourceType[] // 一个用户可以创建多种资源类型
  posts         Post[] // 用户的博客文章
  alist         Alist[]
  blogPosts     BlogPost[] // 用户的博客文章
  userResources UserResource[] // 用户的资源投稿
  vodConfigs    UserVodConfig[]
}

model ResourceType {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  isUserType  Boolean @default(false)
  isEnabled   Boolean @default(true)

  resources     Resource[] // 一个资源类型可以对应多个资源
  creatorId     Int
  creator       User           @relation(fields: [creatorId], references: [id])
  userResources UserResource[] // 一个资源类型可以对应多个用户资源
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Resource {
  id        Int      @id @default(autoincrement())
  name      String
  links     String // 资源链接
  typeId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creatorId Int

  creator User         @relation(fields: [creatorId], references: [id])
  type    ResourceType @relation(fields: [typeId], references: [id])
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  content   String   @db.Text // 文章内容
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creatorId Int

  categories PostToCategory[]
  comments   Comment[]

  creator User @relation(fields: [creatorId], references: [id])
}

model PostCategory {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)

  posts PostToCategory[] // 使用中间表实现多对多关系
}

// 中间表，用于表示文章和分类的多对多关系
model PostToCategory {
  postId     Int
  categoryId Int

  post     Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  category PostCategory @relation(fields: [categoryId], references: [id])

  @@id([postId, categoryId]) // 组合主键，确保唯一性
}

model Alist {
  id        Int      @id @default(autoincrement())
  name      String
  link      String // alist 源链接
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creatorId Int

  creator User @relation(fields: [creatorId], references: [id])
}

model Comment {
  id          Int       @id @default(autoincrement())
  content     String    @db.Text
  author      String?
  email       String?
  website     String?
  avatar      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  postId      Int
  parentId    Int? // 用于回复功能
  post        Post      @relation(fields: [postId], references: [id])
  parent      Comment?  @relation("CommentToComment", fields: [parentId], references: [id])
  replies     Comment[] @relation("CommentToComment")
  likes       Int       @default(0)
  deleteToken String    @unique // 用于评论删除验证

  @@index([postId])
  @@index([parentId])
}

// 博客分类模型
model BlogCategory {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)

  posts BlogPostToCategory[] // 使用中间表实现多对多关系
}

// 博客文章和分类的多对多关系中间表
model BlogPostToCategory {
  postId     Int
  categoryId Int

  post     BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category BlogCategory @relation(fields: [categoryId], references: [id])

  @@id([postId, categoryId]) // 组合主键，确保唯一性
}

// 博客文章模型
model BlogPost {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  content   String   @db.Text
  tags      String[]
  status    String   @default("pending") // pending, published, rejected
  author    User     @relation(fields: [authorId], references: [id])
  authorId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories BlogPostToCategory[] // 使用中间表实现多对多关系
}

// 新增的用户资源模型
model UserResource {
  id          Int      @id @default(autoincrement())
  name        String
  links       String // 资源链接
  typeId      Int
  description String   @db.Text
  status      String   @default("pending") // pending, published, rejected
  size        Int? // 文件大小（字节）
  format      String? // 文件格式
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creatorId   Int

  creator User         @relation(fields: [creatorId], references: [id])
  type    ResourceType @relation(fields: [typeId], references: [id])
}

// 修改 SystemSettings 模型
model SystemSettings {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String   @db.Text
  description String?  @db.Text // 添加配置描述字段
  group       String? // 添加配置分组字段，如 'quark', 'system' 等
  isEnabled   Boolean  @default(true) // 添加启用状态字段
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([group]) // 添加分组索引以提高查询性能
  @@map("system_settings")
}

// 搜索记录模型
model SearchRecord {
  id           Int      @id @default(autoincrement())
  keyword      String   @unique // 添加唯一索引
  count        Int      @default(1)
  lastSearchAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([count])
  @@map("search_records")
}

// UserVodConfig模型 - 用户VOD配置
model UserVodConfig {
  id        Int      @id @default(autoincrement())
  userId    Int
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 用户关联
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

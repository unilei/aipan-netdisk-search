// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
// npx prisma migrate dev --name add_resource_table

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // shadowDatabaseUrl = env("SHADOW_DATABASE_URL") // 生产环境不需要
}

model User {
  id                        Int       @id @default(autoincrement())
  username                  String    @unique
  email                     String    @unique
  password                  String
  role                      String    @default("user") // Possible values: "admin", "user"
  status                    String    @default("active") // Possible values: "active", "disabled"
  avatarStyle               String    @default("avataaars") // 头像风格
  salt                      String? // 用于密码哈希的盐
  points                    Int       @default(0) // 用户积分
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  isVerified                Boolean   @default(false)
  emailVerifiedAt           DateTime?
  emailVerificationRequired Boolean   @default(false)

  resources     Resource[] // 一个用户可以有多个资源
  resourceTypes ResourceType[] // 一个用户可以创建多种资源类型
  posts         Post[] // 用户的博客文章
  alist         Alist[]
  blogPosts     BlogPost[] // 用户的博客文章
  userResources UserResource[] // 用户的资源投稿
  vodConfigs    UserVodConfig[]
  forumTopics   ForumTopic[] // 用户的论坛主题
  forumPosts    ForumPost[] // 用户的论坛回复
  forumTopicReadStates ForumTopicReadState[] // 用户参与主题的未读状态
  notifications Notification[] // 用户的通知

  // Chat related
  messages     ChatMessage[] // 用户发送的消息
  chatRooms    ChatRoomUser[] // 用户加入的聊天室
  createdRooms ChatRoom[] // 用户创建的聊天室

  // Check-in related
  checkIns                  CheckIn[] // 用户的签到记录
  pointsHistory             PointsHistory[] // 用户的积分历史
  transferPointGrants       TransferPointGrant[] // 用户转存限时积分记录
  pointTaskCompletions      PointTaskCompletion[] // 用户积分任务完成记录
  registrationGiftGrant     RegistrationGiftGrant? // 用户注册礼包领取记录
  emailVerificationTokens   EmailVerificationToken[]
  redemptionCodeCampaigns   RedemptionCodeCampaign[]   @relation("RedemptionCodeCampaignCreator")
  redemptionCodeRedemptions RedemptionCodeRedemption[]

  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@index([isVerified])
  @@index([emailVerificationRequired])
  @@index([points])
}

model ResourceType {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  isUserType  Boolean @default(false)
  isEnabled   Boolean @default(true)

  resources     Resource[] // 一个资源类型可以对应多个资源
  creatorId     Int
  creator       User           @relation(fields: [creatorId], references: [id])
  userResources UserResource[] // 一个资源类型可以对应多个用户资源
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([creatorId])
  @@index([isUserType])
  @@index([isEnabled])
  @@index([createdAt])
}

model Resource {
  id        Int      @id @default(autoincrement())
  name      String
  links     String // 资源链接
  typeId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creatorId Int

  creator User         @relation(fields: [creatorId], references: [id])
  type    ResourceType @relation(fields: [typeId], references: [id])

  @@index([creatorId])
  @@index([typeId])
  @@index([createdAt])
  @@index([name])
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  content   String   @db.Text // 文章内容
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creatorId Int

  categories PostToCategory[]
  comments   Comment[]

  creator User @relation(fields: [creatorId], references: [id])

  @@index([creatorId])
  @@index([createdAt])
  @@index([title])
}

model PostCategory {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)

  posts PostToCategory[] // 使用中间表实现多对多关系
}

// 中间表，用于表示文章和分类的多对多关系
model PostToCategory {
  postId     Int
  categoryId Int

  post     Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  category PostCategory @relation(fields: [categoryId], references: [id])

  @@id([postId, categoryId]) // 组合主键，确保唯一性
}

model Alist {
  id              Int       @id @default(autoincrement())
  name            String
  link            String // alist 源链接
  authMode        String    @default("public")
  username        String?
  secretEncrypted String?   @db.Text
  rootPath        String    @default("/")
  enabled         Boolean   @default(true)
  healthStatus    String?
  healthMessage   String?   @db.Text
  lastCheckedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  creatorId       Int

  creator User @relation(fields: [creatorId], references: [id])
}

model Comment {
  id          Int       @id @default(autoincrement())
  content     String    @db.Text
  author      String?
  email       String?
  website     String?
  avatar      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  postId      Int
  parentId    Int? // 用于回复功能
  post        Post      @relation(fields: [postId], references: [id])
  parent      Comment?  @relation("CommentToComment", fields: [parentId], references: [id])
  replies     Comment[] @relation("CommentToComment")
  likes       Int       @default(0)
  deleteToken String    @unique // 用于评论删除验证

  @@index([postId])
  @@index([parentId])
}

// 博客分类模型
model BlogCategory {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)

  posts BlogPostToCategory[] // 使用中间表实现多对多关系
}

// 博客文章和分类的多对多关系中间表
model BlogPostToCategory {
  postId     Int
  categoryId Int

  post     BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category BlogCategory @relation(fields: [categoryId], references: [id])

  @@id([postId, categoryId]) // 组合主键，确保唯一性
}

// 博客文章模型
model BlogPost {
  id              Int      @id @default(autoincrement())
  title           String
  slug            String   @unique
  content         String   @db.Text
  tags            String[]
  status          String   @default("pending") // pending, published, rejected
  rejectionReason String?  @db.Text // 拒绝原因
  postId          Int? // 关联到已发布的 Post 记录
  author          User     @relation(fields: [authorId], references: [id])
  authorId        Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  categories BlogPostToCategory[] // 使用中间表实现多对多关系

  @@index([authorId])
  @@index([status])
  @@index([createdAt])
  @@index([title])
  @@index([tags])
}

// 新增的用户资源模型
model UserResource {
  id          Int      @id @default(autoincrement())
  name        String
  links       String // 资源链接
  typeId      Int
  description String   @db.Text
  status      String   @default("pending") // pending, published, rejected
  size        Int? // 文件大小（字节）
  format      String? // 文件格式
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creatorId   Int

  creator User         @relation(fields: [creatorId], references: [id])
  type    ResourceType @relation(fields: [typeId], references: [id])

  @@index([creatorId])
  @@index([typeId])
  @@index([status])
  @@index([createdAt])
  @@index([name])
  @@index([format])
}

// 修改 SystemSettings 模型
model SystemSettings {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String   @db.Text
  description String?  @db.Text // 添加配置描述字段
  group       String? // 添加配置分组字段，如 'quark', 'system' 等
  isEnabled   Boolean  @default(true) // 添加启用状态字段
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([group]) // 添加分组索引以提高查询性能
  @@map("system_settings")
}

// 搜索记录模型（累计统计）
model SearchRecord {
  id           Int      @id @default(autoincrement())
  keyword      String   @unique // 添加唯一索引
  count        Int      @default(1)
  lastSearchAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([count])
  @@map("search_records")
}

// 每日搜索统计模型（用于精确统计每天的搜索次数）
model DailySearchStats {
  id        Int      @id @default(autoincrement())
  date      DateTime @db.Date // 日期
  keyword   String // 关键词
  count     Int      @default(1) // 当天搜索次数
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, keyword]) // 每天每个关键词只有一条记录
  @@index([date])
  @@index([keyword])
  @@map("daily_search_stats")
}

// UserVodConfig模型 - 用户VOD配置
model UserVodConfig {
  id        Int      @id @default(autoincrement())
  userId    Int
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 用户关联
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TvboxSource {
  id              Int      @id @default(autoincrement())
  name            String
  link            String   @unique @db.Text
  sourceType      String   @default("other") @map("source_type")
  sourceTypeLabel String   @map("source_type_label")
  upstream        String?  @db.Text
  active          Boolean  @default(true)
  firstSeenAt     DateTime @default(now()) @map("first_seen_at")
  lastSeenAt      DateTime @default(now()) @map("last_seen_at")
  lastSyncedAt    DateTime @default(now()) @map("last_synced_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([sourceType])
  @@index([active])
  @@index([lastSeenAt])
  @@index([name])
  @@map("tvbox_sources")
}

model EmailVerificationToken {
  id            Int       @id @default(autoincrement())
  userId        Int
  emailSnapshot String
  tokenHash     String    @unique
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

// 论坛板块模型
model ForumCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String   @db.Text
  slug        String   @unique
  order       Int      @default(0)
  icon        String? // 图标
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topics ForumTopic[]

  @@index([order])
  @@index([createdAt])
}

// 论坛主题模型
model ForumTopic {
  id             Int           @id @default(autoincrement())
  title          String
  content        String
  slug           String        @unique
  isSticky       Boolean       @default(false)
  isLocked       Boolean       @default(false)
  viewCount      Int           @default(0)
  status         String        @default("pending")
  categoryId     Int
  authorId       Int
  lastActivityAt DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  author         User          @relation(fields: [authorId], references: [id])
  category       ForumCategory @relation(fields: [categoryId], references: [id])
  posts          ForumPost[]
  readStates     ForumTopicReadState[]

  @@index([categoryId])
  @@index([authorId])
  @@index([lastActivityAt])
  @@index([status])
}

// 论坛回复模型
model ForumPost {
  id        Int         @id @default(autoincrement())
  content   String
  status    String      @default("pending")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  topicId   Int
  authorId  Int
  parentId  Int? // 添加父回复ID字段，用于回复的回复功能
  author    User        @relation(fields: [authorId], references: [id])
  topic     ForumTopic  @relation(fields: [topicId], references: [id])
  parent    ForumPost?  @relation("PostToPost", fields: [parentId], references: [id], onDelete: SetNull)
  replies   ForumPost[] @relation("PostToPost")
  lastUnreadForStates ForumTopicReadState[] @relation("LastUnreadPost")

  @@index([topicId])
  @@index([authorId])
  @@index([status])
  @@index([parentId])
}

// 论坛参与主题未读状态
model ForumTopicReadState {
  id               Int        @id @default(autoincrement())
  userId           Int
  topicId          Int
  lastReadAt       DateTime?
  unreadCount      Int        @default(0)
  lastUnreadPostId Int?
  lastUnreadAt     DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic          ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  lastUnreadPost ForumPost? @relation("LastUnreadPost", fields: [lastUnreadPostId], references: [id], onDelete: SetNull)

  @@unique([userId, topicId])
  @@index([userId, unreadCount])
  @@index([topicId])
  @@index([lastUnreadAt])
}

// 通知模型
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int // 接收通知的用户ID
  type      String // 通知类型：'reply'（回复）, 'mention'（提及）, 'topic'（新主题）等
  title     String // 通知标题
  content   String   @db.Text // 通知内容
  isRead    Boolean  @default(false) // 是否已读
  relatedId Int? // 相关内容的ID（如主题ID或回复ID）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// 聊天室模型
model ChatRoom {
  id                 Int       @id @default(autoincrement())
  name               String // 聊天室名称
  description        String? // 聊天室描述
  type               String // 聊天室类型: 'group', 'private'
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  creatorId          Int // 创建者ID
  isPublic           Boolean   @default(false) // 是否是公开聊天室
  avatar             String? // 聊天室头像
  privateKey         String?   @unique // 一对一私聊的稳定用户对 key
  lastMessageAt      DateTime? // 收件箱排序用的最后消息时间
  sourceForumTopicId Int? // 从论坛发起私信时的来源主题

  creator  User           @relation(fields: [creatorId], references: [id])
  users    ChatRoomUser[] // 聊天室用户
  messages ChatMessage[] // 聊天室消息

  @@index([creatorId])
  @@index([type])
  @@index([lastMessageAt])
  @@index([sourceForumTopicId])
}

// 聊天室用户关系模型
model ChatRoomUser {
  userId     Int
  roomId     Int
  joinedAt   DateTime  @default(now())
  role       String    @default("member") // 用户在聊天室中的角色: 'admin', 'member'
  lastReadAt DateTime? // 当前成员最后阅读该会话的时间

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([userId, roomId])
  @@index([userId])
  @@index([roomId])
}

// 聊天消息模型
model ChatMessage {
  id        Int      @id @default(autoincrement())
  content   String // 消息内容
  userId    Int // 发送者ID
  roomId    Int // 聊天室ID
  createdAt DateTime @default(now())
  replyToId Int? // 回复的消息ID，用于消息回复功能
  isRead    Boolean  @default(false) // 是否已读
  type      String   @default("text") // 消息类型: 'text', 'image', 'file'
  fileUrl   String? // 文件URL，用于图片和文件消息

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  room    ChatRoom      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  replyTo ChatMessage?  @relation("ReplyToMessage", fields: [replyToId], references: [id], onDelete: SetNull)
  replies ChatMessage[] @relation("ReplyToMessage")

  @@index([userId])
  @@index([roomId])
  @@index([createdAt])
  @@index([replyToId])
}

// 用户签到记录模型
model CheckIn {
  id              Int      @id @default(autoincrement())
  userId          Int // 用户ID
  checkInDate     DateTime @db.Date // 签到日期
  points          Int // 本次签到获得的积分
  consecutiveDays Int // 连续签到天数
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, checkInDate]) // 确保用户每天只能签到一次
  @@index([userId])
  @@index([checkInDate])
  @@index([consecutiveDays])
}

// 用户积分历史记录模型
model PointsHistory {
  id          Int       @id @default(autoincrement())
  userId      Int // 用户ID
  points      Int // 积分变化数量（正数为获得，负数为消费）
  type        String // 积分类型：'checkin'（签到）, 'bonus'（奖励）, 'consume'（消费）
  description String?   @db.Text // 积分变化描述
  relatedId   Int? // 关联记录ID（如签到记录ID）
  expiresAt   DateTime? // 限时积分过期时间，null 表示永久积分
  createdAt   DateTime  @default(now())

  user                     User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  transferPointGrant       TransferPointGrant?
  pointTaskCompletion      PointTaskCompletion?
  registrationGiftGrant    RegistrationGiftGrant?
  redemptionCodeRedemption RedemptionCodeRedemption?

  @@index([userId])
  @@index([type])
  @@index([expiresAt])
  @@index([createdAt])
}

// 用户转存限时积分发放记录
model TransferPointGrant {
  id                  Int      @id @default(autoincrement())
  userId              Int
  shareId             String
  transferFingerprint String
  points              Int
  expiresAt           DateTime
  pointsHistoryId     Int?     @unique
  createdAt           DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  pointsHistory PointsHistory? @relation(fields: [pointsHistoryId], references: [id], onDelete: SetNull)

  @@unique([userId, shareId])
  @@unique([userId, transferFingerprint])
  @@index([userId])
  @@index([shareId])
  @@index([transferFingerprint])
  @@index([expiresAt])
  @@index([createdAt])
}

// 可配置积分任务
model PointTask {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  title       String
  description String?  @db.Text
  url         String
  points      Int
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  claimLimit  Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  completions PointTaskCompletion[]

  @@index([enabled])
  @@index([sortOrder])
  @@index([createdAt])
}

// 用户积分任务领取记录
model PointTaskCompletion {
  id              Int      @id @default(autoincrement())
  userId          Int
  taskId          Int
  claimNo         Int      @default(1)
  points          Int
  pointsHistoryId Int?     @unique
  createdAt       DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  task          PointTask      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  pointsHistory PointsHistory? @relation(fields: [pointsHistoryId], references: [id], onDelete: SetNull)

  @@unique([userId, taskId, claimNo])
  @@index([userId])
  @@index([taskId])
  @@index([createdAt])
}

// 用户注册限时积分礼包发放记录
model RegistrationGiftGrant {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  points          Int
  expiresAt       DateTime
  source          String   @default("auto")
  pointsHistoryId Int?     @unique
  createdAt       DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  pointsHistory PointsHistory? @relation(fields: [pointsHistoryId], references: [id], onDelete: SetNull)

  @@index([expiresAt])
  @@index([source])
  @@index([createdAt])
}

model RedemptionCodeCampaign {
  id                     Int       @id @default(autoincrement())
  name                   String
  description            String?   @db.Text
  rewardType             String    @default("points")
  points                 Int
  pointsExpiresInMinutes Int?
  enabled                Boolean   @default(true)
  startsAt               DateTime?
  endsAt                 DateTime?
  maxRedemptionsPerUser  Int       @default(1)
  createdById            Int?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  createdBy   User?                      @relation("RedemptionCodeCampaignCreator", fields: [createdById], references: [id], onDelete: SetNull)
  codes       RedemptionCode[]
  redemptions RedemptionCodeRedemption[]

  @@index([enabled])
  @@index([startsAt])
  @@index([endsAt])
  @@index([createdAt])
}

model RedemptionCode {
  id             Int      @id @default(autoincrement())
  campaignId     Int
  codeHash       String   @unique
  codePrefix     String?
  codeSuffix     String?
  batchName      String?
  maxRedemptions Int?
  usedCount      Int      @default(0)
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  campaign    RedemptionCodeCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  redemptions RedemptionCodeRedemption[]

  @@index([campaignId])
  @@index([enabled])
  @@index([batchName])
  @@index([createdAt])
}

model RedemptionCodeRedemption {
  id              Int       @id @default(autoincrement())
  userId          Int
  campaignId      Int
  codeId          Int
  points          Int
  expiresAt       DateTime?
  pointsHistoryId Int?      @unique
  ipHash          String?
  userAgentHash   String?
  createdAt       DateTime  @default(now())

  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign      RedemptionCodeCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  code          RedemptionCode         @relation(fields: [codeId], references: [id], onDelete: Cascade)
  pointsHistory PointsHistory?         @relation(fields: [pointsHistoryId], references: [id], onDelete: SetNull)

  @@unique([userId, codeId])
  @@index([userId])
  @@index([campaignId])
  @@index([codeId])
  @@index([createdAt])
}

// 导航分类模型
model NavigationCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique // 分类名称
  slug      String   @unique // 分类标识符
  sortOrder Int      @default(0) // 排序
  isActive  Boolean  @default(true) // 是否启用
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items NavigationItem[] // 分类下的导航项

  @@index([sortOrder])
  @@index([isActive])
  @@index([createdAt])
}

// 导航项模型
model NavigationItem {
  id          Int      @id @default(autoincrement())
  categoryId  Int // 关联分类ID
  title       String // 导航项标题
  path        String // 路径
  icon        String // 图标类名
  description String? // 描述（可选）
  sortOrder   Int      @default(0) // 排序
  isActive    Boolean  @default(true) // 是否启用
  target      String   @default("_self") // 打开方式（_self, _blank）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category NavigationCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([sortOrder])
  @@index([isActive])
  @@index([createdAt])
}

// 举报模型
model Report {
  id            Int       @id @default(autoincrement())
  contentType   String // 举报内容类型: 'post', 'comment', 'topic', 'message', 'resource'
  contentId     String // 被举报内容的ID
  contentTitle  String? // 被举报内容的标题（可选）
  reason        String // 举报原因: 'spam', 'illegal', 'pornography', 'violence', 'harassment', 'copyright', 'privacy', 'false', 'other'
  description   String    @db.Text // 详细描述
  reporterEmail String? // 举报者邮箱（可选）
  reporterIp    String? // 举报者IP地址
  status        String    @default("pending") // 处理状态: 'pending', 'reviewing', 'resolved', 'rejected'
  adminNote     String?   @db.Text // 管理员备注
  handledBy     Int? // 处理者ID
  handledAt     DateTime? // 处理时间
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([contentType])
  @@index([contentId])
  @@index([status])
  @@index([createdAt])
  @@index([reporterIp])
}

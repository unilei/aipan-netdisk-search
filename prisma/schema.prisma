// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
// npx prisma migrate dev --name add_resource_table

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL") // 添加这一行
}

model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique
  email       String   @unique
  password    String
  role        String   @default("user") // Possible values: "admin", "user"
  status      String   @default("active") // Possible values: "active", "disabled"
  avatarStyle String   @default("avataaars") // 头像风格
  salt        String? // 用于密码哈希的盐
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isVerified  Boolean  @default(false)

  resources     Resource[] // 一个用户可以有多个资源
  resourceTypes ResourceType[] // 一个用户可以创建多种资源类型
  posts         Post[] // 用户的博客文章
  alist         Alist[]
  blogPosts     BlogPost[] // 用户的博客文章
  userResources UserResource[] // 用户的资源投稿
  vodConfigs    UserVodConfig[]
  forumTopics   ForumTopic[] // 用户的论坛主题
  forumPosts    ForumPost[] // 用户的论坛回复
  notifications Notification[] // 用户的通知

  // Chat related
  messages     ChatMessage[] // 用户发送的消息
  chatRooms    ChatRoomUser[] // 用户加入的聊天室
  createdRooms ChatRoom[] // 用户创建的聊天室
}

model ResourceType {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  isUserType  Boolean @default(false)
  isEnabled   Boolean @default(true)

  resources     Resource[] // 一个资源类型可以对应多个资源
  creatorId     Int
  creator       User           @relation(fields: [creatorId], references: [id])
  userResources UserResource[] // 一个资源类型可以对应多个用户资源
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Resource {
  id        Int      @id @default(autoincrement())
  name      String
  links     String // 资源链接
  typeId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creatorId Int

  creator User         @relation(fields: [creatorId], references: [id])
  type    ResourceType @relation(fields: [typeId], references: [id])
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  content   String   @db.Text // 文章内容
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creatorId Int

  categories PostToCategory[]
  comments   Comment[]

  creator User @relation(fields: [creatorId], references: [id])
}

model PostCategory {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)

  posts PostToCategory[] // 使用中间表实现多对多关系
}

// 中间表，用于表示文章和分类的多对多关系
model PostToCategory {
  postId     Int
  categoryId Int

  post     Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  category PostCategory @relation(fields: [categoryId], references: [id])

  @@id([postId, categoryId]) // 组合主键，确保唯一性
}

model Alist {
  id        Int      @id @default(autoincrement())
  name      String
  link      String // alist 源链接
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creatorId Int

  creator User @relation(fields: [creatorId], references: [id])
}

model Comment {
  id          Int       @id @default(autoincrement())
  content     String    @db.Text
  author      String?
  email       String?
  website     String?
  avatar      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  postId      Int
  parentId    Int? // 用于回复功能
  post        Post      @relation(fields: [postId], references: [id])
  parent      Comment?  @relation("CommentToComment", fields: [parentId], references: [id])
  replies     Comment[] @relation("CommentToComment")
  likes       Int       @default(0)
  deleteToken String    @unique // 用于评论删除验证

  @@index([postId])
  @@index([parentId])
}

// 博客分类模型
model BlogCategory {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)

  posts BlogPostToCategory[] // 使用中间表实现多对多关系
}

// 博客文章和分类的多对多关系中间表
model BlogPostToCategory {
  postId     Int
  categoryId Int

  post     BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category BlogCategory @relation(fields: [categoryId], references: [id])

  @@id([postId, categoryId]) // 组合主键，确保唯一性
}

// 博客文章模型
model BlogPost {
  id              Int      @id @default(autoincrement())
  title           String
  slug            String   @unique
  content         String   @db.Text
  tags            String[]
  status          String   @default("pending") // pending, published, rejected
  rejectionReason String?  @db.Text // 拒绝原因
  postId          Int? // 关联到已发布的 Post 记录
  author          User     @relation(fields: [authorId], references: [id])
  authorId        Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  categories BlogPostToCategory[] // 使用中间表实现多对多关系
}

// 新增的用户资源模型
model UserResource {
  id          Int      @id @default(autoincrement())
  name        String
  links       String // 资源链接
  typeId      Int
  description String   @db.Text
  status      String   @default("pending") // pending, published, rejected
  size        Int? // 文件大小（字节）
  format      String? // 文件格式
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creatorId   Int

  creator User         @relation(fields: [creatorId], references: [id])
  type    ResourceType @relation(fields: [typeId], references: [id])
}

// 修改 SystemSettings 模型
model SystemSettings {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String   @db.Text
  description String?  @db.Text // 添加配置描述字段
  group       String? // 添加配置分组字段，如 'quark', 'system' 等
  isEnabled   Boolean  @default(true) // 添加启用状态字段
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([group]) // 添加分组索引以提高查询性能
  @@map("system_settings")
}

// 搜索记录模型
model SearchRecord {
  id           Int      @id @default(autoincrement())
  keyword      String   @unique // 添加唯一索引
  count        Int      @default(1)
  lastSearchAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([count])
  @@map("search_records")
}

// UserVodConfig模型 - 用户VOD配置
model UserVodConfig {
  id        Int      @id @default(autoincrement())
  userId    Int
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 用户关联
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// 论坛板块模型
model ForumCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String   @db.Text
  slug        String   @unique
  order       Int      @default(0)
  icon        String? // 图标
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topics ForumTopic[]
}

// 论坛主题模型
model ForumTopic {
  id             Int           @id @default(autoincrement())
  title          String
  content        String
  slug           String        @unique
  isSticky       Boolean       @default(false)
  isLocked       Boolean       @default(false)
  viewCount      Int           @default(0)
  status         String        @default("pending")
  categoryId     Int
  authorId       Int
  lastActivityAt DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  author         User          @relation(fields: [authorId], references: [id])
  category       ForumCategory @relation(fields: [categoryId], references: [id])
  posts          ForumPost[]

  @@index([categoryId])
  @@index([authorId])
  @@index([lastActivityAt])
  @@index([status])
}

// 论坛回复模型
model ForumPost {
  id        Int         @id @default(autoincrement())
  content   String
  status    String      @default("pending")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  topicId   Int
  authorId  Int
  parentId  Int? // 添加父回复ID字段，用于回复的回复功能
  author    User        @relation(fields: [authorId], references: [id])
  topic     ForumTopic  @relation(fields: [topicId], references: [id])
  parent    ForumPost?  @relation("PostToPost", fields: [parentId], references: [id], onDelete: SetNull)
  replies   ForumPost[] @relation("PostToPost")

  @@index([topicId])
  @@index([authorId])
  @@index([status])
  @@index([parentId])
}

// 通知模型
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int // 接收通知的用户ID
  type      String // 通知类型：'reply'（回复）, 'mention'（提及）, 'topic'（新主题）等
  title     String // 通知标题
  content   String   @db.Text // 通知内容
  isRead    Boolean  @default(false) // 是否已读
  relatedId Int? // 相关内容的ID（如主题ID或回复ID）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// 聊天室模型
model ChatRoom {
  id          Int      @id @default(autoincrement())
  name        String // 聊天室名称
  description String? // 聊天室描述
  type        String // 聊天室类型: 'group', 'private'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creatorId   Int // 创建者ID
  isPublic    Boolean  @default(false) // 是否是公开聊天室
  avatar      String? // 聊天室头像

  creator  User           @relation(fields: [creatorId], references: [id])
  users    ChatRoomUser[] // 聊天室用户
  messages ChatMessage[] // 聊天室消息

  @@index([creatorId])
  @@index([type])
}

// 聊天室用户关系模型
model ChatRoomUser {
  userId   Int
  roomId   Int
  joinedAt DateTime @default(now())
  role     String   @default("member") // 用户在聊天室中的角色: 'admin', 'member'

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([userId, roomId])
  @@index([userId])
  @@index([roomId])
}

// 聊天消息模型
model ChatMessage {
  id        Int      @id @default(autoincrement())
  content   String // 消息内容
  userId    Int // 发送者ID
  roomId    Int // 聊天室ID
  createdAt DateTime @default(now())
  replyToId Int? // 回复的消息ID，用于消息回复功能
  isRead    Boolean  @default(false) // 是否已读
  type      String   @default("text") // 消息类型: 'text', 'image', 'file'
  fileUrl   String? // 文件URL，用于图片和文件消息

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  room    ChatRoom      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  replyTo ChatMessage?  @relation("ReplyToMessage", fields: [replyToId], references: [id], onDelete: SetNull)
  replies ChatMessage[] @relation("ReplyToMessage")

  @@index([userId])
  @@index([roomId])
  @@index([createdAt])
  @@index([replyToId])
}
